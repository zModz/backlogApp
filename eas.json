{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
    "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "BUILD_ENV": "dev"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "env": {
        "BUILD_ENV": "preview"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "BUILD_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
